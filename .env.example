# === PULSAR website env (NEXT_PUBLIC_*) ===
# After deploying contracts, set these to flip the site from "preview" to "live".

# Deployed $PULSAR ERC-20 address on Base mainnet
NEXT_PUBLIC_PULSAR_TOKEN=0x0000000000000000000000000000000000000000

# Deployed PulsarStaking address on Base mainnet
NEXT_PUBLIC_PULSAR_STAKING=0x0000000000000000000000000000000000000000

# Uniswap V2 pair address on Base (used for AMM detection in the UI)
NEXT_PUBLIC_UNISWAP_V2_PAIR=0x0000000000000000000000000000000000000000

# WalletConnect project id (https://cloud.walletconnect.com — free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=pulsar-demo-project-id

# Optional RPC overrides (defaults work for read-only)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
